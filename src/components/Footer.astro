---
const today = new Date();
const SITE = 'https://jeffw5.github.io/Website';
---

<footer>
	<div class="footer-inner">
		<div class="footer-links">
			<a href="https://jeffw5.github.io/Value/index.html">Portfolio</a>
			<a href={`${SITE}/avatar.html`}>Ask Jeffrey</a>
			<a href="https://www.linkedin.com" target="_blank" rel="noopener">LinkedIn</a>
			<a href="mailto:jeffrey@enablingvalue.com">Contact</a>
		</div>
		<div class="footer-meta">
			<span>The Value Enablement Group, LLC · Deerfield, Illinois</span>
			<span class="values">Planet › People › Profit</span>
		</div>
		<div class="footer-copy">&copy; {today.getFullYear()} Jeffrey Wallk. All rights reserved.</div>
	</div>
</footer>

<style>
	footer {
		margin-top: 4em;
		padding: 2.5em 1.5em 3em;
		background: var(--bg-panel);
		border-top: 1px solid var(--border-subtle);
		color: var(--text-secondary);
		text-align: center;
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 0.9em;
		align-items: center;
	}
	.footer-links {
		display: flex;
		gap: 1.25em;
		flex-wrap: wrap;
		justify-content: center;
	}
	.footer-links a {
		color: var(--text-primary);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
	}
	.footer-links a:hover { color: var(--text-accent); }
	.footer-meta {
		display: flex;
		gap: 0.75em 1.5em;
		flex-wrap: wrap;
		justify-content: center;
		font-size: 0.85rem;
	}
	.values {
		color: var(--text-accent);
		letter-spacing: 0.04em;
		font-weight: 600;
	}
	.footer-copy {
		font-size: 0.8rem;
		opacity: 0.7;
	}
</style>

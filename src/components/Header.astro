---
import HeaderLink from './HeaderLink.astro';
// Main site lives in a different repo at /Website. The logo and "Home" always
// return there. Blog is the only internal section.  
const SITE = 'https://jeffw5.github.io/Website';
const LOGO = 'https://jeffw5.github.io/Website/logo.png';
---
<header>
	<nav>
		<a class="brand" href={`${SITE}/index.html`} target="_top" aria-label="Go to main site">
			<img src={LOGO} alt="The Value Enablement Group" class="brand-logo"
				onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" />
			<span class="brand-fallback">VEG</span>
		</a>
		<div class="nav-links" id="navLinks">
			<a href={`${SITE}/about.html`}>About</a>
			<a href={`${SITE}/frameworks.html`}>Frameworks</a>
			<a href={`${SITE}/services.html`}>Services</a>
			<a href="https://jeffw5.github.io/Value/index.html">Portfolio</a>
			<HeaderLink href={import.meta.env.BASE_URL}>Blog</HeaderLink>
			<a class="ask" href={`${SITE}/avatar.html`}>Ask Jeffrey ›</a>
		</div>
		<button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="navLinks">
			<span></span><span></span><span></span>
		</button>
	</nav>
</header>
<style>
	header {
		margin: 0;
		background: var(--bg-panel);
		border-bottom: 1px solid var(--border-subtle);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 72px;
		display: grid;
		grid-template-columns: 1fr auto 1fr;   /* brand | centered menu | balancing space */
		align-items: center;
		gap: 1.5rem;
	}
	/* Brand / logo — always returns to the main site */
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		text-decoration: none;
		flex-shrink: 0;
		justify-self: start;
	}
	.brand-logo {
		width: 44px;
		height: 44px;
		object-fit: contain;
		background: #ffffff;        /* white background — the logo is designed for white */
		border: none;
		border-radius: 6px;
		padding: 4px;               /* keeps the logo off the rounded corners — no clipping */
	}
	.brand-fallback {
		display: none;
		font-weight: 700;
		color: var(--text-accent);
		border: 1px solid var(--border-subtle);
		border-radius: 8px;
		padding: 0.35rem 0.5rem;
	}
	/* Nav links — mirrors the main-site nav (DM Mono · uppercase · gold accent) */
	.nav-links {
		display: flex;
		align-items: center;
		gap: 1.75rem;
		flex-wrap: wrap;
		justify-self: center;
		justify-content: center;
	}
	.nav-links :global(a) {
		font-family: var(--mono);
		font-size: 0.65rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		font-weight: 400;
		color: rgba(244, 240, 232, 0.6);
		text-decoration: none;
		white-space: nowrap;
		transition: color 0.2s ease;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--accent-gold, #c8a96e);
	}
	/* "Ask Jeffrey" call-to-action — gold pill, matches the main site */
	.nav-links :global(a.ask) {
		color: var(--blueprint, #0d1b2a);
		background: var(--accent-gold, #c8a96e);
		padding: 0.5rem 1.1rem;
		border-radius: 6px;
		transition: opacity 0.2s ease;
	}
	.nav-links :global(a.ask:hover) {
		color: var(--blueprint, #0d1b2a);
		opacity: 0.85;
	}

	/* Hamburger toggle — hidden on desktop, shown on mobile (mirrors main site) */
	.nav-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 38px;
		height: 38px;
		padding: 7px;
		background: none;
		border: none;
		cursor: pointer;
		flex-shrink: 0;
	}
	.nav-toggle span {
		display: block;
		width: 100%;
		height: 2px;
		background: var(--accent-gold, #c8a96e);
		transition: transform 0.3s ease, opacity 0.3s ease;
	}
	.nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
	.nav-toggle.open span:nth-child(2) { opacity: 0; }
	.nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

	@media (max-width: 820px) {
		/* Header collapses to: brand (left) · hamburger (right) */
		nav {
			display: flex;
			justify-content: space-between;
			align-items: center;
			height: 72px;
			gap: 1rem;
			position: relative;        /* anchors the fold-down menu */
		}
		.nav-toggle { display: flex; }

		/* The menu folds into a dropdown list, exactly like the main site.
		   Anchored to the sticky <header> so it spans the full width. */
		.nav-links {
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			flex-direction: column;
			align-items: flex-start;
			justify-content: flex-start;
			gap: 1.5rem;
			padding: 0 1.5em;
			background: var(--bg-panel);
			border-bottom: 1px solid var(--border-subtle);
			max-height: 0;
			overflow: hidden;
			opacity: 0;
			pointer-events: none;
			transition: max-height 0.3s ease, opacity 0.3s ease, padding 0.3s ease;
			z-index: 200;
		}
		.nav-links.open {
			max-height: 80vh;
			opacity: 1;
			pointer-events: auto;
			padding: 1.5em;
		}
	}
</style>

<script>
	const navToggle = document.getElementById('navToggle');
	const navLinks = document.getElementById('navLinks');
	if (navToggle && navLinks) {
		navToggle.addEventListener('click', () => {
			const open = navToggle.classList.toggle('open');
			navLinks.classList.toggle('open', open);
			navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
		});
		// Close the menu after a link is tapped
		navLinks.querySelectorAll('a').forEach((a) => {
			a.addEventListener('click', () => {
				navToggle.classList.remove('open');
				navLinks.classList.remove('open');
				navToggle.setAttribute('aria-expanded', 'false');
			});
		});
	}
</script>
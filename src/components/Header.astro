---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
// Main site lives in a different repo at /Website. The logo and "Home" always
// return there. Blog is the only internal section.
const SITE = 'https://jeffw5.github.io/Website';
const LOGO = 'https://jeffw5.github.io/Website/logo.png';
---
<header>
	<nav>
		<a class="brand" href={SITE} aria-label="Back to jeffw5.github.io/Website home">
			<img src={LOGO} alt="The Value Enablement Group" class="brand-logo"
				onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" />
			<span class="brand-fallback">VEG</span>
			<span class="brand-title">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<a href={`${SITE}/index.html`}>Home</a>
			<a href={`${SITE}/about.html`}>About</a>
			<a href={`${SITE}/services.html`}>Services</a>
			<a href="https://jeffw5.github.io/Value/index.html">Demos</a>
			<HeaderLink href={import.meta.env.BASE_URL}>Blog</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}tags`}>Tags</HeaderLink>
			<a class="ask" href={`${SITE}/avatar.html`}>Ask Jeffrey ›</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		background: var(--bg-panel);
		border-bottom: 1px solid var(--border-subtle);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 72px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}
	/* Brand / logo — always returns to the main site */
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		text-decoration: none;
		flex-shrink: 0;
	}
	.brand-logo {
		width: 38px;
		height: 38px;
		object-fit: contain;
		border: 1px solid var(--border-subtle);
		border-radius: 8px;
		background: var(--bg-dark-core);
	}
	.brand-fallback {
		display: none;
		font-weight: 700;
		color: var(--text-accent);
		border: 1px solid
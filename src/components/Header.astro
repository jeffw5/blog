---
import HeaderLink from './HeaderLink.astro';
// Main site lives in a different repo at /Website. The logo and "Home" always
// return there. Blog is the only internal section.  
const SITE = 'https://jeffw5.github.io/Website';
const LOGO = 'https://jeffw5.github.io/Website/logo.png';
---
<header>
	<nav>
		<a class="brand" href={`${SITE}/index.html`} target="_top" aria-label="Go to main site">
			<img src={LOGO} alt="The Value Enablement Group" class="brand-logo"
				onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" />
			<span class="brand-fallback">VEG</span>
		</a>
		<div class="nav-links">
			<a href={`${SITE}/about.html`}>About</a>
			<a href={`${SITE}/frameworks.html`}>Frameworks</a>
			<a href={`${SITE}/services.html`}>Services</a>
			<a href="https://jeffw5.github.io/Value/index.html">Portfolio</a>
			<HeaderLink href={import.meta.env.BASE_URL}>Blog</HeaderLink>
			<a class="ask" href={`${SITE}/avatar.html`}>Ask Jeffrey ›</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		background: var(--bg-panel);
		border-bottom: 1px solid var(--border-subtle);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 72px;
		display: grid;
		grid-template-columns: 1fr auto 1fr;   /* brand | centered menu | balancing space */
		align-items: center;
		gap: 1.5rem;
	}
	/* Brand / logo — always returns to the main site */
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		text-decoration: none;
		flex-shrink: 0;
		justify-self: start;
	}
	.brand-logo {
		width: 44px;
		height: 44px;
		object-fit: contain;
		background: #ffffff;        /* white background — the logo is designed for white */
		border: none;
		border-radius: 6px;
		padding: 4px;               /* keeps the logo off the rounded corners — no clipping */
	}
	.brand-fallback {
		display: none;
		font-weight: 700;
		color: var(--text-accent);
		border: 1px solid var(--border-subtle);
		border-radius: 8px;
		padding: 0.35rem 0.5rem;
	}
	/* Nav links — mirrors the main-site nav (DM Mono · uppercase · gold accent) */
	.nav-links {
		display: flex;
		align-items: center;
		gap: 1.75rem;
		flex-wrap: wrap;
		justify-self: center;
		justify-content: center;
	}
	.nav-links :global(a) {
		font-family: var(--mono);
		font-size: 0.65rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		font-weight: 400;
		color: rgba(244, 240, 232, 0.6);
		text-decoration: none;
		white-space: nowrap;
		transition: color 0.2s ease;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--accent-gold, #c8a96e);
	}
	/* "Ask Jeffrey" call-to-action — gold pill, matches the main site */
	.nav-links :global(a.ask) {
		color: var(--blueprint, #0d1b2a);
		background: var(--accent-gold, #c8a96e);
		padding: 0.5rem 1.1rem;
		border-radius: 6px;
		transition: opacity 0.2s ease;
	}
	.nav-links :global(a.ask:hover) {
		color: var(--blueprint, #0d1b2a);
		opacity: 0.85;
	}
	@media (max-width: 820px) {
		nav { height: auto; grid-template-columns: 1fr; justify-items: center; gap: 0.75rem; padding: 0.75em 1em; }
		.brand { justify-self: center; }
		.nav-links { justify-self: center; justify-content: center; }
	}
</style>
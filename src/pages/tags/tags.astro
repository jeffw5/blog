---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL; // "/blog/" — always trailing-slashed

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// "Knowledge Engineering" -> "knowledge-engineering" for safe matching
const slugify = (s) =>
  s.toLowerCase().trim().replace(/[^\w]+/g, '-').replace(/^-+|-+$/g, '');

const tagCounts = new Map();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()]
  .map(([name, count]) => ({ name, count, slug: slugify(name) }))
  .sort((a, b) => a.name.localeCompare(b.name));

const counts = tags.map((t) => t.count);
const minC = Math.min(...counts, 1);
const maxC = Math.max(...counts, 1);

// Scale a tag's count to a font size between 0.9rem and 1.9rem
const sizeFor = (c) => {
  if (maxC === minC) return '1.15';
  const t = (c - minC) / (maxC - minC);
  return (0.9 + t * 1.0).toFixed(2);
};
---

<BaseLayout title="Tags" description="Browse blog posts by tag">
  <div class="tagcloud-page">
    <header class="tc-head">
      <h1>Browse by Tag</h1>
      <p class="tc-status" id="tc-status">Showing all {posts.length} posts</p>
    </header>

    <div class="tc-layout">
      <!-- LEFT: tag cloud -->
      <aside class="tc-cloud" aria-label="Tag cloud">
        <button class="tc-tag tc-all is-active" data-slug="__all__" data-name="All">
          All <span class="tc-count">{posts.length}</span>
        </button>
        {tags.map((tag) => (
          <button
            class="tc-tag"
            data-slug={tag.slug}
            data-name={tag.name}
            style={`font-size:${sizeFor(tag.count)}rem`}
          >
            {tag.name}<span class="tc-count">{tag.count}</span>
          </button>
        ))}
      </aside>

      <!-- RIGHT: post list -->
      <section class="tc-list" aria-label="Posts">
        <ul>
          {posts.map((post) => (
            <li class="tc-row" data-tags={(post.data.tags ?? []).map(slugify).join(' ')}>
              <a href={`${base}blog/${post.id}/`}>
                <span class="tc-title">{post.data.title}</span>
                <span class="tc-date"><FormattedDate date={post.data.pubDate} /></span>
              </a>
              {(post.data.tags ?? []).length > 0 && (
                <div class="tc-rowtags">
                  {post.data.tags.map((t) => (
                    <span class="tc-pill" data-slug={slugify(t)}>{t}</span>
                  ))}
                </div>
              )}
            </li>
          ))}
        </ul>
        <p class="tc-empty" id="tc-empty" hidden>No posts with that tag.</p>
      </section>
    </div>
  </div>
</BaseLayout>

<!-- Widen the shared <main> just for this page (only ships on /tags) -->
<style is:global>
  body main { width: 1000px; }
</style>

<style>
  .tagcloud-page { padding-top: 0.5rem; }
  .tc-head h1 { margin: 0 0 0.25rem; }
  .tc-status {
    margin: 0 0 1.75rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .tc-layout {
    display: grid;
    grid-template-columns: minmax(220px, 280px) 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* Tag cloud */
  .tc-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.6rem;
    align-content: flex-start;
    position: sticky;
    top: 88px; /* clears the 72px sticky header */
  }
  .tc-tag {
    cursor: pointer;
    line-height: 1.2;
    background: var(--bg-panel);
    color: var(--text-primary);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    padding: 0.28em 0.75em;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .tc-tag:hover {
    border-color: var(--text-accent);
    background: var(--bg-panel-elevated);
  }
  .tc-tag.is-active {
    background: var(--text-accent);
    border-color: var(--text-accent);
    color: var(--bg-dark-core);
    font-weight: 600;
  }
  .tc-count {
    margin-left: 0.45em;
    font-size: 0.7em;
    color: var(--text-secondary);
  }
  .tc-tag.is-active .tc-count { color: var(--bg-dark-core); opacity: 0.7; }
  .tc-all { font-weight: 600; }

  /* Post list */
  .tc-list ul { list-style: none; margin: 0; padding: 0; }
  .tc-row {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .tc-row a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
    color: var(--text-primary);
  }
  .tc-row a:hover .tc-title,
  .tc-row a:hover .tc-date { color: var(--text-accent); }
  .tc-title { font-weight: 600; line-height: 1.25; }
  .tc-date {
    flex: none;
    font-size: 0.8rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .tc-rowtags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.45rem;
  }
  .tc-pill {
    cursor: pointer;
    font-size: 0.72rem;
    padding: 0.12em 0.6em;
    border-radius: 999px;
    background: var(--bg-panel-elevated);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    transition: all 0.15s;
  }
  .tc-pill:hover { color: var(--text-accent); border-color: var(--text-accent); }
  .tc-pill.is-active {
    background: var(--text-accent);
    border-color: var(--text-accent);
    color: var(--bg-dark-core);
  }
  .tc-empty { color: var(--text-secondary); padding: 1rem 0; }

  @media (max-width: 720px) {
    .tc-layout { grid-template-columns: 1fr; gap: 1.5rem; }
    .tc-cloud { position: static; }
  }
</style>

<script>
  const cloud = document.querySelector('.tc-cloud');
  const rows = Array.from(document.querySelectorAll('.tc-row'));
  const status = document.getElementById('tc-status');
  const empty = document.getElementById('tc-empty');
  const total = rows.length;

  function applyFilter(slug) {
    let shown = 0;

    cloud.querySelectorAll('.tc-tag').forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.slug === slug);
    });

    rows.forEach((row) => {
      const rowTags = row.dataset.tags ? row.dataset.tags.split(' ') : [];
      const match = slug === '__all__' || rowTags.includes(slug);
      row.hidden = !match;
      if (match) shown++;
      row.querySelectorAll('.tc-pill').forEach((pill) => {
        pill.classList.toggle('is-active', slug !== '__all__' && pill.dataset.slug === slug);
      });
    });

    if (slug === '__all__') {
      status.textContent = `Showing all ${total} posts`;
    } else {
      const name = cloud.querySelector(`.tc-tag[data-slug="${slug}"]`)?.dataset.name ?? slug;
      status.textContent = `${shown} post${shown === 1 ? '' : 's'} tagged "${name}"`;
    }
    empty.hidden = shown !== 0;
  }

  // Click a tag in the cloud (click the active one again to clear)
  cloud.addEventListener('click', (e) => {
    const btn = e.target.closest('.tc-tag');
    if (!btn) return;
    const slug = btn.dataset.slug;
    applyFilter(btn.classList.contains('is-active') && slug !== '__all__' ? '__all__' : slug);
  });

  // Click a pill under a post to filter by that tag too
  document.querySelector('.tc-list').addEventListener('click', (e) => {
    const pill = e.target.closest('.tc-pill');
    if (!pill) return;
    e.preventDefault();
    applyFilter(pill.dataset.slug);
  });
</script>